<?xml version="1.0"?>
<!-- A simple 3-DOF arm, primitives only so it renders without mesh files.
     Standard URDF Z-up convention; the loader stands it up in the Y-up world. -->
<robot name="simple_arm">

  <material name="base">  <color rgba="0.30 0.34 0.42 1"/></material>
  <material name="blue">  <color rgba="0.31 0.69 1.00 1"/></material>
  <material name="green"> <color rgba="0.43 0.90 0.66 1"/></material>
  <material name="yellow"><color rgba="1.00 0.82 0.40 1"/></material>

  <link name="base_link">
    <inertial>
      <mass value="3.0"/>
      <inertia ixx="0.03" ixy="0" ixz="0" iyy="0.03" iyz="0" izz="0.05"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.05"/>
      <geometry><box size="0.3 0.3 0.1"/></geometry>
      <material name="base"/>
    </visual>
  </link>

  <joint name="j1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0.1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="50" velocity="3"/>
    <dynamics damping="0.05"/>
  </joint>

  <link name="link1">
    <inertial>
      <origin xyz="0 0 0.2"/>
      <mass value="1.2"/>
      <inertia ixx="0.018" ixy="0" ixz="0" iyy="0.018" iyz="0" izz="0.0015"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.2"/>
      <geometry><cylinder radius="0.05" length="0.4"/></geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.2"/>
      <geometry><cylinder radius="0.05" length="0.4"/></geometry>
    </collision>
  </link>

  <joint name="j2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <origin xyz="0 0 0.4"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.4" upper="2.4" effort="50" velocity="3"/>
    <dynamics damping="0.04"/>
  </joint>

  <link name="link2">
    <inertial>
      <origin xyz="0 0 0.2"/>
      <mass value="1.0"/>
      <inertia ixx="0.015" ixy="0" ixz="0" iyy="0.015" iyz="0" izz="0.0012"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.2"/>
      <geometry><cylinder radius="0.045" length="0.4"/></geometry>
      <material name="green"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.2"/>
      <geometry><cylinder radius="0.045" length="0.4"/></geometry>
    </collision>
  </link>

  <joint name="j3" type="revolute">
    <parent link="link2"/>
    <child link="link3"/>
    <origin xyz="0 0 0.4"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.4" upper="2.4" effort="30" velocity="3"/>
    <dynamics damping="0.03"/>
  </joint>

  <link name="link3">
    <inertial>
      <origin xyz="0 0 0.15"/>
      <mass value="0.6"/>
      <inertia ixx="0.006" ixy="0" ixz="0" iyy="0.006" iyz="0" izz="0.0006"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.15"/>
      <geometry><cylinder radius="0.04" length="0.3"/></geometry>
      <material name="yellow"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.15"/>
      <geometry><cylinder radius="0.04" length="0.3"/></geometry>
    </collision>
  </link>

</robot>
